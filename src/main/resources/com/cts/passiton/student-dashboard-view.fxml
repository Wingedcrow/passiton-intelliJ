<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #f9fbe7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.passiton.StudentDashboardController">

   <VBox alignment="TOP_CENTER" prefHeight="750.0" prefWidth="186.0" spacing="10.0" style="-fx-background-color: #dcedc8; -fx-padding: 25;                 -fx-border-color: #c5e1a5; -fx-border-width: 0 2 0 0;" HBox.hgrow="NEVER">

      <Label style="-fx-font-size: 22px; -fx-font-weight: bold;                     -fx-text-fill: #33691e;" text="PassItOn" />
      <Label style="-fx-font-size: 13px; -fx-text-fill: #558b2f;" text="Student Portal" />

      <Separator prefWidth="180.0" />

      <!-- Nav buttons -->
      <Button fx:id="btnProfile" onAction="#showProfile" prefHeight="44.0" prefWidth="185.0" style="-fx-background-color: #f9fbe7; -fx-text-fill: #33691e;                      -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10;                      -fx-alignment: CENTER-LEFT; -fx-font-weight: bold;                      -fx-background-radius: 8; -fx-border-color: #c5e1a5;                      -fx-border-radius: 8;" text="Profile Settings" />

      <Button fx:id="btnSupplies" onAction="#showSupplies" prefHeight="44.0" prefWidth="185.0" style="-fx-background-color: #f9fbe7; -fx-text-fill: #33691e;                      -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10;                      -fx-alignment: CENTER-LEFT; -fx-font-weight: bold;                      -fx-background-radius: 8; -fx-border-color: #c5e1a5;                      -fx-border-radius: 8;" text="Supplies" />

      <Button fx:id="btnMarketboard" onAction="#showMarketboard" prefHeight="44.0" prefWidth="185.0" style="-fx-background-color: #f9fbe7; -fx-text-fill: #33691e;                      -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10;                      -fx-alignment: CENTER-LEFT; -fx-font-weight: bold;                      -fx-background-radius: 8; -fx-border-color: #c5e1a5;                      -fx-border-radius: 8;" text="Marketboard" />

      <Button fx:id="btnTrades" onAction="#showTrades" prefHeight="44.0" prefWidth="185.0" style="-fx-background-color: #f9fbe7; -fx-text-fill: #33691e;                      -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10;                      -fx-alignment: CENTER-LEFT; -fx-font-weight: bold;                      -fx-background-radius: 8; -fx-border-color: #c5e1a5;                      -fx-border-radius: 8;" text="Your Trades" />


      <VBox VBox.vgrow="ALWAYS" />

      <Separator prefWidth="180.0" />

      <Button fx:id="btnLogout" onAction="#actionLogout" prefHeight="44.0" prefWidth="185.0" style="-fx-background-color: #ef9a9a; -fx-text-fill: #c62828;                      -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10;                      -fx-alignment: CENTER-LEFT; -fx-font-weight: bold;                      -fx-background-radius: 20; -fx-border-radius: 20;                      -fx-border-color: #e57373;" text="🚪  Logout" />

   </VBox>

   <VBox prefHeight="750.0" spacing="15.0" style="-fx-background-color: #f9fbe7; -fx-padding: 40;" HBox.hgrow="ALWAYS">


      <Label fx:id="lblWelcome" style="-fx-font-size: 28px; -fx-font-weight: bold;                     -fx-text-fill: #33691e;" text="Welcome back!" />

      <Label style="-fx-font-size: 13px; -fx-text-fill: #8d9e5a;                     -fx-font-style: italic;" text="Select an option from the sidebar to get started." />

      <Separator prefWidth="800.0" />


  <!-- PICTURE PLACEHOLDER -->

      <StackPane prefHeight="450.0" prefWidth="800.0" style="-fx-background-color: white;                         -fx-background-radius: 12;                         -fx-border-color: #c5e1a5;                         -fx-border-radius: 12;                         -fx-border-width: 1.5;">
         <ImageView fitHeight="454.0" fitWidth="831.0" pickOnBounds="true">
            <image>
               <Image url="@../../../img/StudentDashboardImage1.jpg" />
            </image>
         </ImageView>
      </StackPane>

      <Separator prefWidth="800.0" />

   </VBox>

</HBox>
